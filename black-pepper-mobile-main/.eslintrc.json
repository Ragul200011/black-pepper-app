{
  "root": true,
  "extends": ["@react-native-community", "prettier"],
  "plugins": ["react", "react-hooks", "react-native"],
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "parserOptions": {
    "ecmaFeatures": { "jsx": true }
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "react/prop-types": "off"
  }
}
